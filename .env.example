# コピーして .env にリネームし、値を設定してください（.env は Git に含めません）

# MySQL コンテナ初期化・運用用（Spring には渡さない）
MYSQL_ROOT_PASSWORD=change-me-strong-password
MYSQL_DATABASE=household_book

# Flyway 専用（マイグレーション時だけ Spring が使う）
MYSQL_FLYWAY_USER=flyway_user
MYSQL_FLYWAY_PASSWORD=change-me-flyway-password

# アプリ専用（常時の DataSource）
MYSQL_APP_USER=app_user
MYSQL_APP_PASSWORD=change-me-app-password

# Spring Boot JDBC URL（パスは MYSQL_DATABASE と一致させる）
# single-host 構成: 同一 Docker ネットワーク内のため useSSL=false（RDS 移行時は sslMode 必須化）
SPRING_DATASOURCE_URL_PROD=jdbc:mysql://mysql:3306/household_book?useSSL=false&allowPublicKeyRetrieval=true&characterEncoding=UTF-8&serverTimezone=UTC
SPRING_DATASOURCE_URL_DEV=jdbc:mysql://localhost:3306/household_book?useSSL=false&allowPublicKeyRetrieval=true&characterEncoding=UTF-8&serverTimezone=UTC

# Cognito (JWT 検証)
COGNITO_JWK_SET_URL=
COGNITO_ISSUER_URL=
COGNITO_CLIENT_ID=

# OpenAI
OPENAI_API_KEY=
OPENAI_API_URL=https://api.openai.com/v1/chat/completions

# CORS
CORS_ALLOWED_ORIGINS=http://localhost:3000
