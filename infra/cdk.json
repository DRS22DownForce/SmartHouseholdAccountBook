{
  "app": "mvn -e -q compile exec:java",
  "watch": {
    "include": ["**"],
    "exclude": [
      "README.md",
      "cdk*.json",
      "target/**",
      "cdk.out/**",
      "node_modules/**",
      "package*.json"
    ]
  },
  "context": {
    "@aws-cdk/aws-lambda:recognizeLayerVersion": true,
    "@aws-cdk/core:checkSecretUsage": true,
    "@aws-cdk/core:target-partitions": ["aws", "aws-cn"],
    "@aws-cdk-containers/ecs-service-extensions:enableDefaultLogDriver": true,
    "@aws-cdk/aws-ec2:uniqueImdsv2TemplateName": true,
    "@aws-cdk/aws-ecs:arnFormatIncludesClusterName": true,
    "@aws-cdk/aws-iam:minimizePolicies": true,
    "@aws-cdk/core:validateSnapshotRemovalPolicy": true,
    "@aws-cdk/aws-apigateway:disableCloudWatchRole": true,
    "@aws-cdk/core:enablePartitionLiterals": true,
    "@aws-cdk/aws-events:eventsTargetQueueSameAccount": true,
    "@aws-cdk/aws-ecs:disableExplicitDeploymentControllerForCircuitBreaker": true,
    "@aws-cdk/aws-iam:importedRoleStackSafeDefaultPolicyName": true,
    "@aws-cdk/aws-s3:createDefaultLoggingPolicy": true,
    "@aws-cdk/aws-sns-subscriptions:restrictSqsDescryption": true,
    "@aws-cdk/aws-apigateway:authorizerChangeDeploymentLogicalId": true,
    "@aws-cdk/aws-ec2:restrictDefaultSecurityGroup": true,

    "projectName": "smart-household",
    "awsRegion": "ap-northeast-1",
    "instanceType": "t4g.small",
    "rootVolumeGiB": 30,
    "gitRepositoryUrl": "https://github.com/DRS22DownForce/SmartHouseholdAccountBook.git",
    "gitRepositoryBranch": "master",
    "allowedSshCidr": "0.0.0.0/0",
    "enableSshAccess": false,

    "domainName": "smart-household-account-book.com",
    "hostedZoneName": "smart-household-account-book.com",
    "hostedZoneId": "ZXXXXXXXXXXXXX",
    "certbotEmail": "you@example.com",

    "cognitoUserPoolId": "ap-northeast-1_XXXXXXXXX",
    "cognitoClientId": "your-cognito-app-client-id"
  }
}
